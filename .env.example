# IvyLens Social Operator Environment Variables
# Copy this file to .env and fill in your actual values

# Telegram Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ALLOWED_USER_IDS=comma_separated_user_ids
TELEGRAM_WEBHOOK_SECRET=random_webhook_secret_string

# Groq API Configuration
GROQ_API_KEY=your_groq_api_key_here

# Tavily API Configuration
TAVILY_API_KEY=your_tavily_api_key_here

# PostFast API Configuration
POSTFAST_API_KEY=your_postfast_api_key_here

# Vercel KV Database (for persistence)
KV_URL=your_vercel_kv_url
KV_REST_API_URL=your_vercel_kv_rest_api_url
KV_REST_API_TOKEN=your_vercel_kv_rest_api_token
KV_REST_API_READ_ONLY_TOKEN=your_vercel_kv_read_only_token

# Application Configuration
APP_URL=https://your-vercel-app.vercel.app
NODE_ENV=production
CRON_SECRET=random_cron_secret_string

# Manatal ATS Integration
MANATAL_API_URL=https://api.manatal.com/open/v3
MANATAL_API_KEY=your_manatal_api_key_here

# Multi-Brand Configuration (optional)
BRAND_SLUG=ivylens

# Operating Mode Configuration
DEFAULT_MODE=auto # auto, draft, approval
ENABLE_LOGGING=true
DEBUG_MODE=false